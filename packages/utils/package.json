{
  "name": "@falka/utils",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./crypto": {
      "types": "./dist/crypto.d.ts",
      "default": "./dist/crypto.js"
    },
    "./date": {
      "types": "./dist/date.d.ts",
      "default": "./dist/date.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "default": "./dist/logger.js"
    },
    "./storage": {
      "types": "./dist/storage.d.ts",
      "default": "./dist/storage.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@falka/logger": "workspace:*",
    "pino": "^9.14.0"
  },
  "devDependencies": {
    "@falka/eslint-config": "workspace:*",
    "@falka/typescript-config": "workspace:*",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3"
  }
}
