{
  "name": "@olshop/utils",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./crypto": {
      "types": "./dist/crypto.d.ts",
      "default": "./dist/crypto.js"
    },
    "./date": {
      "types": "./dist/date.d.ts",
      "default": "./dist/date.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "default": "./dist/logger.js"
    },
    "./storage": {
      "types": "./dist/storage.d.ts",
      "default": "./dist/storage.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@olshop/eslint-config": "workspace:*",
    "@olshop/typescript-config": "workspace:*",
    "eslint": "^9.24.0",
    "typescript": "^5.8.3"
  }
}
