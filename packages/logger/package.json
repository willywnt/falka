{
  "name": "@falka/logger",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./correlation": {
      "types": "./dist/correlation.d.ts",
      "default": "./dist/correlation.js"
    },
    "./correlation-id": {
      "types": "./dist/correlation-id.d.ts",
      "default": "./dist/correlation-id.js"
    },
    "./sanitize": {
      "types": "./dist/sanitize.d.ts",
      "default": "./dist/sanitize.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@falka/eslint-config": "workspace:*",
    "@falka/typescript-config": "workspace:*",
    "eslint": "^9.39.4",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3"
  }
}
