# =============================================================================
# Olshop — Next.js client environment (public, embedded in browser bundle)
# Copy to apps/web/.env.local
# =============================================================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Olshop

# Server-only variables live in the monorepo root .env file.
# Next.js also reads apps/web/.env.local — copy DATABASE_URL, AUTH_SECRET,
# R2_*, REDIS_URL, and other server vars here for local dev convenience.
# See docs/environment.md for the full variable reference.
