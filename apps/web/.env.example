# =============================================================================
# Olshop — Next.js client environment (public, embedded in browser bundle)
# Copy to apps/web/.env.local
# =============================================================================

# Desktop browser — use https://localhost when DEV_HTTPS=true (phone camera needs HTTPS on LAN)
NEXT_PUBLIC_APP_URL=https://localhost:3000
NEXT_PUBLIC_APP_NAME=Olshop

# Mobile scanner / QR — your PC LAN IP (ipconfig → IPv4), must be https://
# NEXT_PUBLIC_PAIRING_URL=https://192.168.1.10:3000
# PAIRING_LAN_HOST=192.168.1.10

# Dev server (pnpm dev:web) — true enables self-signed HTTPS on port 3000
DEV_HTTPS=true

# Server-only variables live in the monorepo root .env file.
# Next.js also reads apps/web/.env.local — copy DATABASE_URL, AUTH_SECRET,
# R2_*, REDIS_URL, and other server vars here for local dev convenience.
#
# Auth (desktop): keep localhost when developing on this PC
# AUTH_URL=http://localhost:3000
# NEXTAUTH_URL=http://localhost:3000
#
# See docs/environment.md for the full variable reference.
