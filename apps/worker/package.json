{
  "name": "@palka/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "node scripts/with-env.mjs tsx watch src/index.ts",
    "start": "node scripts/with-env.mjs node dist/index.js",
    "enqueue": "pnpm --filter @palka/queue build && node scripts/with-env.mjs node scripts/enqueue-test.mjs",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@palka/config": "workspace:*",
    "@palka/db": "workspace:*",
    "@palka/logger": "workspace:*",
    "@palka/queue": "workspace:*",
    "@palka/utils": "workspace:*",
    "@sentry/node": "^10.59.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@palka/eslint-config": "workspace:*",
    "@palka/typescript-config": "workspace:*",
    "@types/node": "^26.0.0",
    "eslint": "^9.39.4",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
