{
  "apps/web/**/*.{ts,tsx,js,mjs}": [
    "eslint --fix --config apps/web/eslint.config.mjs",
    "prettier --write"
  ],
  "packages/**/*.{ts,tsx,js,mjs}": [
    "eslint --fix --config packages/utils/eslint.config.mjs",
    "prettier --write"
  ],
  "scripts/**/*.mjs": ["eslint --fix --config eslint.config.mjs", "prettier --write"],
  "*.{json,md,yml,yaml,css}": "prettier --write"
}
