{
  "CORSRules": [
    {
      "AllowedOrigins": [
        "https://your-domain.com",
        "https://www.your-domain.com",
        "https://your-app.vercel.app"
      ],
      "AllowedMethods": ["GET", "PUT", "HEAD"],
      "AllowedHeaders": ["*"],
      "ExposeHeaders": ["ETag", "Content-Length", "Content-Type"],
      "MaxAgeSeconds": 3600
    }
  ]
}
