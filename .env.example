# Server
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/olshop
AUTH_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=olshop-recordings
R2_PUBLIC_URL=https://your-bucket.r2.dev

# Marketplace (optional OAuth credentials — for future integration)
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
TOKOPEDIA_CLIENT_ID=
TOKOPEDIA_CLIENT_SECRET=
MARKETPLACE_ENCRYPTION_SECRET=change-me-to-a-secure-random-string-at-least-32-chars

# Client
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Olshop

# Logging
LOG_LEVEL=debug

# Database seed (optional)
SEED_ADMIN_EMAIL=admin@olshop.local
SEED_ADMIN_PASSWORD=Admin123!
SEED_DEMO_PASSWORD=Demo123!
